<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" xmlns:gz="http://gazebosim.org/schema">
  <xacro:macro name="mecanum_wheel"
               params="name parent:=base_link radius:=0.04 width:=0.04 mass:=0.3
                       pos_x:=0.0 pos_y:=0.0 pos_z:=${radius} mesh_file:=''">

    <link name="${name}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <xacro:if value="${mesh_file == ''}">
            <cylinder radius="${radius}" length="${width}"/>
          </xacro:if>
          <xacro:unless value="${mesh_file == ''}">
            <mesh filename="${mesh_file}" scale="1 1 1"/>
          </xacro:unless>
        </geometry>
        <material name="${name}_rubber"><color rgba="0.1 0.1 0.1 1"/></material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry><cylinder radius="${radius}" length="${width}"/></geometry>
        
        </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia
          ixx="${0.5*mass*radius*radius}"
          ixy="0" ixz="0"
          iyy="${(1.0/12.0)*mass*(3*radius*radius + width*width)}"
          iyz="0"
          izz="${0.5*mass*radius*radius}"/>
      </inertial>
    </link>

    <gazebo reference="${name}_wheel">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>   <mu2>0.7</mu2>  <kp>200000.0</kp>
              <kd>5000.0</kd>
              
              <xacro:if value="${name == 'front_left'}">
                <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
              </xacro:if>
              <xacro:if value="${name == 'rear_left'}">
                <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
              </xacro:if>
              <xacro:if value="${name == 'front_right'}">
                <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
              </xacro:if>
              <xacro:if value="${name == 'rear_right'}">
                <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
              </xacro:if>
            </ode>
          </friction>
        </surface>
      </collision>
    </gazebo>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="${parent}"/>
      <child  link="${name}_wheel"/> <origin xyz="${pos_x} ${pos_y} ${pos_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="20.0" velocity="100.0"/>
      <dynamics damping="0.0" friction="0.0"/>
    </joint>
  </xacro:macro>
</robot>